// File: apps/api/prisma/schema.prisma

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// ─────────────────────────────────────────────────────────────────
// YAANA Transit — PostgreSQL schema via Prisma ORM
//
// DB: PostgreSQL (Docker local → Railway production)
// ORM: Prisma v7
// 
// Key design decisions:
//   • Single User table with role enum (RBAC)
//   • Soft deletes via deletedAt — nothing is ever hard-deleted
//   • All money values stored in PAISE (₹1 = 100 paise) as Int
//     → avoids floating point precision bugs with currency
//   • UUID primary keys (cuid) — safer than sequential IDs for public APIs
//   • Audit timestamps (createdAt, updatedAt) on every table
//
// ROLES:
//   YAANA_ADMIN      → Full system access (Yana internal staff)
//   CORPORATE_ADMIN  → Manages their own company's users & bookings
//   CORPORATE_USER   → Creates/views their own bookings only
//
// AUTH FLOW:
//   Admin creates user → InvitationToken sent via email
//   User activates → sets password → logs in
//   Login returns AccessToken (JWT, short-lived) +
//   RefreshToken (DB-stored, rotated, httpOnly cookie)
// ─────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  YAANA_ADMIN // Yana internal — full access
  CORPORATE_ADMIN // Client company admin — manages their company
  CORPORATE_USER // Client company employee — limited access
}

enum UserStatus {
  PENDING // Invited, not yet activated
  ACTIVE // Activated and can log in
  INACTIVE // Disabled by admin
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum BookingStatus {
  ENQUIRY // Initial request, no vehicle assigned yet
  CONFIRMED // Yana confirmed, vehicle assigned
  ONGOING // Trip in progress
  COMPLETED // Trip done
  CANCELLED // Cancelled by either party
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum VehicleCategory {
  SEDAN // Maruti Dzire
  MUV // Ertiga / Rumion
  SUV // Innova Crysta
  PREMIUM_SUV // Innova HyCross
  PREMIUM // Kia Carnival
  LUXURY // Mercedes / BMW
}

enum ServiceType {
  CHAUFFEUR_DRIVEN
  AIRPORT_TRANSFER
  OUTSTATION
  ETS // Employee Transportation Services
  EVENTS
  CORPORATE_LEASE
}

enum OfficeType {
  HQ
  BRANCH
  FRANCHISE
}

// ─────────────────────────────────────────
// COMPANY
// The "customer" in B2B is always a Company.
// Individual users belong to a Company.
// All data (bookings, invoices) is scoped to companyId.
// ─────────────────────────────────────────

model Company {
  id            String        @id @default(cuid())
  name          String
  gstNumber     String? // GST registration number (optional)
  pan           String? // PAN number (optional)
  address       String?
  city          String?
  state         String?
  pincode       String?
  phone         String?
  email         String?
  website       String?
  status        CompanyStatus @default(ACTIVE)
  contractStart DateTime? // When contract began
  contractEnd   DateTime? // When contract ends (null = ongoing)
  creditLimit   Decimal?      @db.Decimal(10, 2) // Max outstanding amount allowed

  // Relations
  users    User[]
  bookings Booking[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

// ─────────────────────────────────────────
// USER
// YAANA_ADMIN users have companyId = null.
// All corporate users must belong to a Company.
// ─────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String? // Null until user activates account
  name         String
  phone        String?
  role         Role       @default(CORPORATE_USER)
  status       UserStatus @default(PENDING)

  // Company linkage — null for YAANA_ADMIN only
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Who created this user (audit trail)
  createdById  String?
  createdBy    User?   @relation("CreatedByRelation", fields: [createdById], references: [id])
  createdUsers User[]  @relation("CreatedByRelation")

  // Relations
  refreshTokens    RefreshToken[]
  invitationTokens InvitationToken[]
  bookings         Booking[] // Bookings created by this user

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("users")
}

// ─────────────────────────────────────────
// REFRESH TOKEN
// Stored in DB — one row per active session.
// Rotated on every use (old token deleted, new issued).
// Sent as httpOnly cookie, never in response body.
// ─────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique // hashed value stored, raw value in cookie
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Optional: device/session info for future multi-device support
  userAgent String?
  ipAddress String?

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// INVITATION TOKEN
// Generated when admin creates a user.
// Single-use, 48-hour expiry.
// Used to activate account and set password.
// ─────────────────────────────────────────

model InvitationToken {
  id        String    @id @default(cuid())
  token     String    @unique // random 64-byte hex token
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime // 48 hours from creation
  usedAt    DateTime? // Set when token is consumed — prevents reuse

  createdAt DateTime @default(now())

  @@map("invitation_tokens")
}

// ─────────────────────────────────────────
// VEHICLE
// B2B fleet — no pricePerDay (corporate pricing on request).
// Linked to bookings. Managed by YAANA_ADMIN only.
// ─────────────────────────────────────────

model Vehicle {
  id           String          @id @default(cuid())
  name         String // e.g. "Toyota Innova Crysta"
  category     VehicleCategory
  seats        Int
  registration String?         @unique // Number plate
  year         Int?
  color        String?
  isActive     Boolean         @default(true)
  notes        String?

  // City where vehicle is based
  baseCityId String?
  baseCity   City?   @relation(fields: [baseCityId], references: [id])

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vehicles")
}

// ─────────────────────────────────────────
// CITY
// Cities where Yana Transit operates.
// hasOffice = true means Yana has a physical presence.
// ─────────────────────────────────────────

model City {
  id         String      @id @default(cuid())
  name       String
  state      String
  slug       String      @unique // e.g. "bengaluru", "new-delhi"
  isActive   Boolean     @default(true)
  hasOffice  Boolean     @default(false)
  officeType OfficeType?

  vehicles Vehicle[]
  bookings Booking[] // Bookings originating from this city

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cities")
}

// ─────────────────────────────────────────
// BOOKING
// A booking request from a corporate user.
// Goes through a status workflow managed by admin.
// companyId is denormalized here for fast querying.
// ─────────────────────────────────────────

model Booking {
  id          String        @id @default(cuid())
  referenceNo String        @unique // Human-readable: YT-2025-0001
  status      BookingStatus @default(ENQUIRY)
  serviceType ServiceType

  // Who booked
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  companyId String // Denormalized for fast scoped queries
  company   Company @relation(fields: [companyId], references: [id])

  // Trip details
  pickupCityId   String?
  pickupCity     City?     @relation(fields: [pickupCityId], references: [id])
  pickupAddress  String?
  dropAddress    String?
  startDate      DateTime
  endDate        DateTime?
  passengerCount Int?
  notes          String? // Special requirements

  // Vehicle assignment (done by admin after confirmation)
  vehicleId      String?
  vehicle        Vehicle? @relation(fields: [vehicleId], references: [id])
  chauffeurName  String? // Driver name (simple for now, extend later)
  chauffeurPhone String?

  // Financials
  quotedAmount Decimal? @db.Decimal(10, 2)
  finalAmount  Decimal? @db.Decimal(10, 2)

  invoice Invoice?

  // Admin notes (internal)
  adminNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookings")
}

// ─────────────────────────────────────────
// INVOICE
// One invoice per booking.
// Full GST breakdown as required for B2B India.
// SAC Code: 996411 (Road transport services)
// ─────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique // YT-INV-2025-0001
  status        InvoiceStatus @default(DRAFT)

  // Linked records
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Amounts (all in INR, 2 decimal precision)
  subtotal Decimal @db.Decimal(10, 2)
  cgst     Decimal @default(0) @db.Decimal(10, 2) // 9% for intra-state
  sgst     Decimal @default(0) @db.Decimal(10, 2) // 9% for intra-state
  igst     Decimal @default(0) @db.Decimal(10, 2) // 18% for inter-state
  total    Decimal @db.Decimal(10, 2)

  // GST details
  sacCode    String  @default("996411") // Road transport services
  gstType    String? // "CGST_SGST" or "IGST"
  companyGst String? // Company's GST number at time of invoice
  yanaGst    String? // Yana's GST number

  // Dates
  issueDate DateTime  @default(now())
  dueDate   DateTime?
  paidAt    DateTime?

  // Notes
  notes         String?
  termsAndConds String?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoices")
}

// ─────────────────────────────────────────
// PAYMENT
// Payment records against an invoice.
// Multiple partial payments allowed.
// ─────────────────────────────────────────

model Payment {
  id          String        @id @default(cuid())
  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id])
  amount      Decimal       @db.Decimal(10, 2)
  status      PaymentStatus @default(PENDING)
  method      String? // "bank_transfer", "upi", "cheque", "online"
  referenceNo String? // Bank ref / UTR / Razorpay ID
  notes       String?
  paidAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}
