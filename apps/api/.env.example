# ─────────────────────────────────────────────────────────────────────
# apps/api/.env.example
#
# For local dev: use the docker-compose values below as-is.
# For Railway:   set these in Railway's environment variables UI.
# ─────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (matches docker-compose.yml values) ─────────────────────
# Local dev:
DATABASE_URL="postgresql://yana_user:yana_password@localhost:5432/yana_transit?schema=public"
# Railway (auto-provided, paste from Railway dashboard):
# DATABASE_URL="postgresql://..."

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT (generate a long random string — use: openssl rand -base64 64) ──
JWT_SECRET="replace-this-with-a-long-random-secret-min-64-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-this-with-another-long-random-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# ── MSG91 (OTP via SMS/WhatsApp) ──────────────────────────────────────
# Sign up at msg91.com → API → Auth Key
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_TEMPLATE_ID="your-otp-template-id"
MSG91_SENDER_ID="YANTRN"

# ── Razorpay (payments) ───────────────────────────────────────────────
# Dashboard → Settings → API Keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# ── Cloudinary (car/driver images CDN) ───────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── CORS (which frontends can call this API) ──────────────────────────
# Local dev:
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
# Production (add your Vercel URLs):
# ALLOWED_ORIGINS="https://yanatransit.in,https://admin.yanatransit.in"
